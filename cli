#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

# When the game binary is launched directly (not through `cargo run`),
# CARGO_MANIFEST_DIR is missing and Bevy's AssetServer falls back to the
# directory of the executable, which is `target/debug/` during local dev
# and has no `assets/` folder. Setting BEVY_ASSET_ROOT here gives every
# binary launched from this script, and any child processes it spawns,
# like the multiplayer-test client windows, a stable, project-relative
# asset root.
export BEVY_ASSET_ROOT="$ROOT"

# Build-artifact cleanup retention for the manual `./cli sweep`. cargo never
# garbage-collects old dependency versions or dead incremental caches, so
# target/ creeps toward tens of GB over a project's life. Sweeping is manual
# (not wired into `dev`/`dev-fast`): `cargo sweep --time` keys off file mtime
# and will delete the artifacts of any dependency that simply hasn't been
# rebuilt in that window, forcing a needless recompile on the next launch. We
# don't want housekeeping silently lengthening a dev launch, so run it yourself
# when target/ gets big.
SWEEP_KEEP_DAYS="${ASHWEND_SWEEP_KEEP_DAYS:-30}"

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

close_existing_game() {
  pkill -x "Ashwend" >/dev/null 2>&1 || true
  pkill -x "ashwend" >/dev/null 2>&1 || true
  pkill -f "target/debug/ashwend" >/dev/null 2>&1 || true
}

copy_release_binary() {
  local target="$1"
  local ext=""
  if [[ "$target" == *"windows"* ]]; then
    ext=".exe"
  fi

  local src="target/${target}/release/ashwend${ext}"
  local out_dir="builds/${target}"
  local out="${out_dir}/Ashwend${ext}"

  mkdir -p "$out_dir"
  cp "$src" "$out"
  # No sibling assets/ folder is needed in published builds: every media
  # file is baked into the binary via `EmbeddedAssetsPlugin` (see
  # src/app/embedded_assets.rs). When you add a new media file, add a row
  # there and the next published build picks it up.
  echo "built ${out}"
}

publish_target() {
  local target="$1"

  rustup target add "$target" >/dev/null
  if cargo build --release --target "$target"; then
    copy_release_binary "$target"
  else
    echo "failed to build ${target}; install the target linker/toolchain and rerun ./cli publish" >&2
    return 1
  fi
}

case "$cmd" in
  dev)
    close_existing_game
    cargo run --bin ashwend -- client "$@"
    ;;
  dev-fast)
    close_existing_game
    cargo run --features dev-fast --bin ashwend -- client "$@"
    ;;
  profile)
    close_existing_game
    # `--features profile` enables `bevy/trace_chrome` plus the extra
    # diagnostics plugins. Bevy writes `trace-<unix-ms>.json` to the
    # working directory on exit; load it in chrome://tracing or
    # ui.perfetto.dev. Run release-ish opt levels so the trace reflects
    # something close to shipped perf, `[profile.dev.package."*"]` already
    # builds deps at opt-level 3, so a plain dev build is acceptable here.
    cargo run --features profile --bin ashwend -- client "$@"
    ;;
  server)
    cargo run --bin ashwend -- server "$@"
    ;;
  admin)
    cargo run --bin ashwend -- admin "$@"
    ;;
  multiplayer-test)
    close_existing_game
    cargo build --bin ashwend
    ./target/debug/ashwend multiplayer-test "$@"
    ;;
  check)
    cargo check --locked --all-targets
    ;;
  test)
    cargo test --locked --all-targets
    ;;
  lint)
    cargo fmt --all -- --check
    cargo clippy --locked --all-targets --all-features -- -D warnings
    ;;
  ci)
    # Reproduce the GitHub Quality Gate locally in one command. Mirrors
    # .github/workflows/quality-gate.yml: fmt, clippy (-D warnings), check, and
    # tests, including the `--all-features` leg that exercises the
    # `replication-trace`/`profile`/`dev-fast` cfg-gated code paths a plain
    # `./cli check` (default features only) never compiles, plus the `--release`
    # leg (the only one with `debug_assertions` off) that catches
    # cfg(debug_assertions) mismatches the shipped build would trip on.
    cargo fmt --all -- --check
    cargo clippy --locked --all-targets --all-features -- -D warnings
    cargo check --locked --all-targets --all-features
    cargo clippy --locked --all-targets --release -- -D warnings
    cargo test --locked --all-targets
    ;;
  setup-hooks)
    # Point git at the checked-in hooks dir so `./cli lint` runs before push.
    git config core.hooksPath .githooks
    echo "git hooks enabled (core.hooksPath=.githooks). pre-push now runs ./cli lint."
    ;;
  audit)
    if ! cargo audit --version >/dev/null 2>&1; then
      echo "cargo-audit not installed; installing..." >&2
      cargo install --locked cargo-audit
    fi
    cargo audit --deny warnings "$@"
    ;;
  coverage)
    if cargo llvm-cov --version >/dev/null 2>&1; then
      cargo llvm-cov --all-targets --all-features --text
    else
      cargo test --all-targets
      echo "cargo-llvm-cov is not installed; install it for line coverage text: cargo install cargo-llvm-cov" >&2
    fi
    ;;
  build)
    cargo build --locked "$@"
    ;;
  sweep)
    # Manual artifact trim. Installs cargo-sweep if missing. Pass a day count
    # to override retention, e.g. `./cli sweep 14` keeps only the last 14 days.
    # Heads-up: `--time` keys off mtime, so a too-aggressive value can delete a
    # still-needed dependency's artifacts and trigger a full recompile next run.
    if ! cargo sweep --version >/dev/null 2>&1; then
      echo "cargo-sweep not installed; installing..." >&2
      cargo install --locked cargo-sweep
    fi
    keep="${1:-$SWEEP_KEEP_DAYS}"
    echo "sweeping build artifacts older than ${keep} days..."
    cargo sweep --time "$keep"
    ;;
  publish)
    rm -rf builds
    mkdir -p builds
    failed=0
    for target in \
      aarch64-apple-darwin \
      x86_64-apple-darwin \
      x86_64-unknown-linux-gnu \
      x86_64-pc-windows-gnu
    do
      publish_target "$target" || failed=1
    done
    exit "$failed"
    ;;
  web-build)
    web_dir="$ROOT/website"
    dist_dir="$web_dir/dist/client"
    out="$ROOT/ashwend-web.zip"

    if [[ ! -d "$web_dir/node_modules" ]]; then
      echo "installing website dependencies..." >&2
      (cd "$web_dir" && npm install)
    fi

    echo "building website..."
    (cd "$web_dir" && npm run build)

    if [[ ! -f "$dist_dir/index.html" ]]; then
      echo "website build produced no $dist_dir/index.html" >&2
      exit 1
    fi

    # Cloudflare Pages "Direct Upload" expects the site files at the zip root
    # (index.html on top, not nested under dist/client/), so zip the *contents*
    # of dist/client. Land it at the repo root (gitignored) so it's a one-step
    # drag-and-drop into the dashboard.
    find "$dist_dir" -name '.DS_Store' -delete 2>/dev/null || true
    rm -f "$out"
    (cd "$dist_dir" && zip -r -q -X "$out" . -x '*.DS_Store')

    echo "packaged $(du -h "$out" | cut -f1) -> $out"
    echo "drop it into Cloudflare Pages (Create > Pages > Upload assets / Direct Upload)."
    ;;
  help|*)
    cat <<'EOF'
Usage: ./cli <command> [args]

Commands:
  dev          Close existing Ashwend windows and run the Bevy client.
  dev-fast     Like dev, but with bevy/dynamic_linking for faster rebuilds.
  profile      Like dev, with Chrome tracing + extra diagnostics. Writes trace-*.json on exit.
  server       Run a dedicated authoritative server. Pass --help after server for flags.
  admin        Send an announcement or shutdown command to a dedicated server admin socket.
  multiplayer-test
               Launch a fresh local server + two auto-connecting client windows for multiplayer iteration.
  check        Run cargo check for all targets.
  test         Run unit/integration tests.
  lint         Run rustfmt check and clippy with warnings denied.
  ci           Reproduce the full CI Quality Gate locally (fmt, clippy, check, test, incl. --all-features).
  setup-hooks  Enable the checked-in git hooks (.githooks) so ./cli lint runs on push.
  audit        Run cargo audit against the RustSec advisory database (installs cargo-audit if missing).
  coverage     Print text coverage when cargo-llvm-cov is installed, otherwise run tests.
  build        Run cargo build with any extra args.
  sweep        Trim stale build artifacts (cargo-sweep). Optional day count overrides 30d retention.
  publish      Build release binaries into builds/ for macOS, Linux, and Windows targets.
  web-build    Build the website and zip it to ./ashwend-web.zip (gitignored) for Cloudflare Pages drop-in.
EOF
    ;;
esac
