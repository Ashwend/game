# Icon/texture generation scratch (regenerable, never committed). Only the
# chosen master (art/items/<id>/icon_master_512.png) and the embedded game icon
# (assets/items/<id>/icon.png) are kept; everything below is throwaway.
/art/_staging/
art/items/*/source/
*.contact.png
*.preview.png

# Python bytecode + Blender backups (regenerable, never committed)
__pycache__/
*.blend1
