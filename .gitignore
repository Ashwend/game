/target/
/builds/
/ashwend-web.zip
.DS_Store
/.claude/
/analytics.local.toml
/workos.local.toml

# Icon/texture generation scratch (regenerable, never committed). Only the
# chosen master (art/items/<id>/icon_master_512.png) and the embedded game icon
# (assets/items/<id>/icon.png) are kept; everything below is throwaway.
/art/_staging/
art/items/*/source/
art/textures/candidates/
# runpod-flash CLI state (activity logs, deploy artifacts), written wherever
# the `flash` command runs from. The deployed worker's SOURCE lives in
# runpod/flash_app/ and is committed; this state is not.
.flash/
# Asset-family pipeline dirs (art/ore/ is the template): meshes/ holds the
# raw image-to-3D output (~50 MB per glb) plus the built game outputs, all
# regenerable from the committed candidates/ + prompts.json + selection.json,
# which ARE the authoring record and stay in git.
art/ore/meshes/
art/held/meshes/
# Regenerable per-family picker/review pages (gen_candidates.py --html-only /
# gen_meshes.py --html-only rebuild them from the committed inputs).
art/*/pick.html
art/*/review.html
*.contact.png
*.preview.png

# Python bytecode + Blender backups (regenerable, never committed)
__pycache__/
*.blend1
