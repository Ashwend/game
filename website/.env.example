# ─── Ashwend website ─────────────────────────────────────────────────────────
# Copy to `.env`. Every value here is PUBLIC (the site is static, no backend),
# so none of these are secrets. The WorkOS API key/secret is NOT used here.
#
# On Cloudflare Pages, set these as build-time environment variables instead.

# WorkOS AuthKit client id (public). Without it, the playtest box renders a
# "not wired up" state so the rest of the site still works locally.
# Dashboard → Configuration. Starts with "client_".
VITE_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where AuthKit returns after login — must be registered in
# WorkOS dashboard → Redirects. For a one-pager, point it at the site root.
# Leave unset to use the dashboard default.
VITE_WORKOS_REDIRECT_URI=http://localhost:3000

# Leave UNSET. The SDK defaults to api.workos.com, which serves the OAuth
# `/user_management/authorize` endpoint. Only set this to a custom domain that is
# CNAME'd to WorkOS and proxies the API — NOT the hosted-UI `*.authkit.app`
# domain (that one 404s on /user_management/authorize).
# VITE_WORKOS_API_HOSTNAME=auth.ashwend.game

# Public links surfaced on the page.
VITE_DISCORD_INVITE_URL=https://discord.gg/gVqTumNb8b
VITE_GITHUB_REPO_URL=https://github.com/Ashwend/game

# Canonical origin, used for SEO/Open Graph absolute URLs. No trailing slash.
VITE_SITE_URL=https://ashwend.game
